<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- HomeFlow Typography System - JetBrains Mono -->

    <!-- Display -->
    <style name="Wire.TextAppearance.Display" parent="TextAppearance.Material3.DisplaySmall">
        <item name="fontFamily">@font/jetbrains_mono</item>
        <item name="android:fontFamily">@font/jetbrains_mono</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/colorTextPrimary</item>
        <item name="android:fontWeight">600</item>
    </style>

    <style name="Wire.TextAppearance.DisplaySmall" parent="Wire.TextAppearance.Display">
        <item name="android:textSize">18sp</item>
    </style>

    <!-- Heading -->
    <style name="Wire.TextAppearance.Heading" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="fontFamily">@font/jetbrains_mono</item>
        <item name="android:fontFamily">@font/jetbrains_mono</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/colorTextPrimary</item>
        <item name="android:fontWeight">600</item>
    </style>

    <style name="Wire.TextAppearance.HeadingSmall" parent="Wire.TextAppearance.Heading">
        <item name="android:textSize">15sp</item>
    </style>

    <!-- Title -->
    <style name="Wire.TextAppearance.Title" parent="TextAppearance.Material3.TitleMedium">
        <item name="fontFamily">@font/jetbrains_mono</item>
        <item name="android:fontFamily">@font/jetbrains_mono</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/colorTextPrimary</item>
        <item name="android:fontWeight">600</item>
    </style>

    <!-- Subtitle -->
    <style name="Wire.TextAppearance.Subtitle" parent="TextAppearance.Material3.TitleSmall">
        <item name="fontFamily">@font/jetbrains_mono</item>
        <item name="android:fontFamily">@font/jetbrains_mono</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/colorTextSecondary</item>
        <item name="android:fontWeight">500</item>
    </style>

    <!-- Body -->
    <style name="Wire.TextAppearance.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">@font/jetbrains_mono</item>
        <item name="android:fontFamily">@font/jetbrains_mono</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/colorTextPrimary</item>
        <item name="android:fontWeight">400</item>
    </style>

    <style name="Wire.TextAppearance.BodySmall" parent="Wire.TextAppearance.Body">
        <item name="android:textSize">12sp</item>
    </style>

    <!-- Caption -->
    <style name="Wire.TextAppearance.Caption" parent="TextAppearance.Material3.LabelSmall">
        <item name="fontFamily">@font/jetbrains_mono</item>
        <item name="android:fontFamily">@font/jetbrains_mono</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/colorTextTertiary</item>
        <item name="android:fontWeight">400</item>
    </style>

    <!-- Label (uppercase, tracking) -->
    <style name="Wire.TextAppearance.Label" parent="TextAppearance.Material3.LabelMedium">
        <item name="fontFamily">@font/jetbrains_mono</item>
        <item name="android:fontFamily">@font/jetbrains_mono</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/colorTextTertiary</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:fontWeight">500</item>
    </style>

    <!-- Small (annotations, timestamps) -->
    <style name="Wire.TextAppearance.Small" parent="Wire.TextAppearance.Caption">
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">@color/colorTextHint</item>
    </style>

    <style name="Wire.TextAppearance.XSmall" parent="Wire.TextAppearance.Small">
        <item name="android:textSize">8sp</item>
    </style>
</resources>
