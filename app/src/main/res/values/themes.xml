<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.HomeFlow" parent="Theme.Material3.Light.NoActionBar">
        <!-- Brand colors -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <item name="colorPrimaryContainer">@color/colorPrimaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/colorOnPrimaryContainer</item>
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorOnSecondary">@color/colorOnSecondary</item>
        <item name="colorSecondaryContainer">@color/colorSecondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/colorOnSecondaryContainer</item>
        <item name="colorTertiary">@color/colorTertiary</item>
        <item name="colorOnTertiary">@color/colorOnTertiary</item>
        <item name="colorTertiaryContainer">@color/colorTertiaryContainer</item>
        <item name="colorOnTertiaryContainer">@color/colorOnTertiaryContainer</item>
        <item name="colorError">@color/colorError</item>
        <item name="colorOnError">@color/colorOnError</item>
        <item name="colorErrorContainer">@color/colorErrorContainer</item>
        <item name="colorOnErrorContainer">@color/colorOnErrorContainer</item>

        <!-- Surface & Background -->
        <item name="android:colorBackground">@color/colorBackground</item>
        <item name="colorOnBackground">@color/colorOnBackground</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/colorOnSurface</item>
        <item name="colorSurfaceVariant">@color/colorSurfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/colorOnSurfaceVariant</item>
        <item name="colorOutline">@color/colorOutline</item>
        <item name="colorOutlineVariant">@color/colorOutlineVariant</item>

        <!-- System bars -->
        <item name="android:statusBarColor">@color/colorSurface</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/bottomNavBackground</item>

        <!-- Typography -->
        <item name="android:fontFamily">@font/jetbrains_mono</item>
        <item name="fontFamily">@font/jetbrains_mono</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.HomeFlow.Splash" parent="Theme.HomeFlow">
        <item name="android:windowBackground">@color/colorPrimary</item>
    </style>

    <!-- Dialog style -->
    <style name="Theme.HomeFlow.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="android:fontFamily">@font/jetbrains_mono</item>
    </style>

    <!-- Bottom Sheet style -->
    <style name="Theme.HomeFlow.BottomSheet" parent="Theme.Material3.Light.BottomSheetDialog">
        <item name="android:fontFamily">@font/jetbrains_mono</item>
        <item name="bottomSheetStyle">@style/Widget.HomeFlow.BottomSheet</item>
    </style>

    <style name="Widget.HomeFlow.BottomSheet" parent="Widget.Material3.BottomSheet">
        <item name="shapeAppearance">@style/ShapeAppearance.HomeFlow.BottomSheet</item>
    </style>

    <style name="ShapeAppearance.HomeFlow.BottomSheet" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">20dp</item>
        <item name="cornerSizeTopRight">20dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <!-- Card style -->
    <style name="Widget.HomeFlow.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardElevation">0dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="strokeColor">@color/cardBorder</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardBackgroundColor">@color/cardBackground</item>
    </style>

    <!-- Chip styles -->
    <style name="Widget.HomeFlow.Chip.Filter" parent="Widget.Material3.Chip.Filter">
        <item name="android:fontFamily">@font/jetbrains_mono</item>
        <item name="chipCornerRadius">20dp</item>
    </style>

    <!-- Input style -->
    <style name="Widget.HomeFlow.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/input_stroke_color</item>
        <item name="hintTextColor">@color/colorTextTertiary</item>
        <item name="android:fontFamily">@font/jetbrains_mono</item>
    </style>

    <!-- Button styles -->
    <style name="Widget.HomeFlow.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:fontFamily">@font/jetbrains_mono</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <style name="Widget.HomeFlow.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:fontFamily">@font/jetbrains_mono</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <style name="Widget.HomeFlow.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:fontFamily">@font/jetbrains_mono</item>
    </style>

    <style name="Widget.HomeFlow.Button.Destructive" parent="Widget.Material3.Button">
        <item name="android:fontFamily">@font/jetbrains_mono</item>
        <item name="cornerRadius">12dp</item>
        <item name="backgroundTint">@color/colorErrorContainer</item>
        <item name="android:textColor">@color/colorError</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <!-- FAB style -->
    <style name="Widget.HomeFlow.FAB" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/fabBackground</item>
        <item name="tint">@color/fabIcon</item>
        <item name="fabSize">normal</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Material3.Corner.Full</item>
    </style>
</resources>
