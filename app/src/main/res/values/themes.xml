<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Hom8" parent="Theme.Material3.Light.NoActionBar">
        <!-- Brand colors -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <item name="colorPrimaryContainer">@color/colorPrimaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/colorOnPrimaryContainer</item>
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorOnSecondary">@color/colorOnSecondary</item>
        <item name="colorSecondaryContainer">@color/colorSecondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/colorOnSecondaryContainer</item>
        <item name="colorTertiary">@color/colorTertiary</item>
        <item name="colorOnTertiary">@color/colorOnTertiary</item>
        <item name="colorTertiaryContainer">@color/colorTertiaryContainer</item>
        <item name="colorOnTertiaryContainer">@color/colorOnTertiaryContainer</item>
        <item name="colorError">@color/colorError</item>
        <item name="colorOnError">@color/colorOnError</item>
        <item name="colorErrorContainer">@color/colorErrorContainer</item>
        <item name="colorOnErrorContainer">@color/colorOnErrorContainer</item>

        <!-- Surface & Background -->
        <item name="android:colorBackground">@color/colorBackground</item>
        <item name="colorOnBackground">@color/colorOnBackground</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/colorOnSurface</item>
        <item name="colorSurfaceVariant">@color/colorSurfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/colorOnSurfaceVariant</item>
        <item name="colorOutline">@color/colorOutline</item>
        <item name="colorOutlineVariant">@color/colorOutlineVariant</item>

        <!-- System bars -->
        <item name="android:statusBarColor">@color/colorSurface</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/bottomNavBackground</item>

        <!-- Typography -->
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="fontFamily">@font/plus_jakarta_sans</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.Hom8.Splash" parent="Theme.Hom8">
        <item name="android:windowBackground">@color/colorPrimary</item>
    </style>

    <!-- Dialog style -->
    <style name="Theme.Hom8.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
    </style>

    <!-- Bottom Sheet style -->
    <style name="Theme.Hom8.BottomSheet" parent="Theme.Material3.Light.BottomSheetDialog">
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="bottomSheetStyle">@style/Widget.Hom8.BottomSheet</item>
    </style>

    <style name="Widget.Hom8.BottomSheet" parent="Widget.Material3.BottomSheet">
        <item name="shapeAppearance">@style/ShapeAppearance.Hom8.BottomSheet</item>
    </style>

    <style name="ShapeAppearance.Hom8.BottomSheet" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">20dp</item>
        <item name="cornerSizeTopRight">20dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <!-- Card style -->
    <style name="Widget.Hom8.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardElevation">0dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="strokeColor">@color/cardBorder</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardBackgroundColor">@color/cardBackground</item>
    </style>

    <!-- Chip styles -->
    <style name="Widget.Hom8.Chip.Filter" parent="Widget.Material3.Chip.Filter">
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="chipCornerRadius">20dp</item>
    </style>

    <!-- Input style -->
    <style name="Widget.Hom8.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/input_stroke_color</item>
        <item name="hintTextColor">@color/colorTextTertiary</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
    </style>

    <!-- Button styles (Touch-Target Size Min 48dp) -->
    <style name="Widget.Hom8.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="Widget.Hom8.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="Widget.Hom8.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="Widget.Hom8.Button.Destructive" parent="Widget.Material3.Button">
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="cornerRadius">12dp</item>
        <item name="backgroundTint">@color/colorErrorContainer</item>
        <item name="android:textColor">@color/colorError</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <!-- FAB style (Thumb-zone prominent) -->
    <style name="Widget.Hom8.FAB" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/fabBackground</item>
        <item name="tint">@color/fabIcon</item>
        <item name="fabSize">normal</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Material3.Corner.Full</item>
        <item name="fabCustomSize">56dp</item>
    </style>

    <!-- Premium Styles -->
    <style name="Widget.Hom8.BottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
    </style>

    <style name="Widget.Hom8.BottomNav.Premium">
        <item name="android:layout_margin">16dp</item>
        <item name="android:elevation">8dp</item>
        <item name="cornerRadius">24dp</item>
        <item name="backgroundTint">@color/bottomNavPremiumBg</item>
    </style>

    <style name="Widget.Hom8.BottomNav.ActiveIndicator" parent="">
        <item name="android:width">40dp</item>
        <item name="android:height">36dp</item>
        <item name="android:color">@color/colorPrimaryContainer</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Hom8.BottomNav.ActiveIndicator</item>
    </style>

    <style name="ShapeAppearance.Hom8.BottomNav.ActiveIndicator" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="Widget.Hom8.Card.Glass" parent="Widget.Hom8.Card">
        <item name="cardElevation">2dp</item>
        <item name="cardCornerRadius">20dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/glassStroke</item>
        <item name="cardBackgroundColor">@color/glassSurface</item>
    </style>

    <style name="Widget.Hom8.ExtendedFAB" parent="Widget.Material3.ExtendedFloatingActionButton.Primary">
        <item name="backgroundTint">@color/colorPrimary</item>
        <item name="android:textColor">@color/white</item>
        <item name="iconTint">@color/white</item>
        <item name="elevation">12dp</item>
        <item name="cornerRadius">28dp</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Typography Hierarchy -->
    <style name="TextAppearance.Hom8" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="android:textColor">@color/colorTextPrimary</item>
    </style>

    <style name="TextAppearance.Hom8.Headline1">
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.Hom8.Headline2">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="TextAppearance.Hom8.Body">
        <item name="android:textSize">15sp</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>

    <style name="TextAppearance.Hom8.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/colorTextSecondary</item>
    </style>

    <style name="TextAppearance.Hom8.Prefix">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
    </style>
</resources>
