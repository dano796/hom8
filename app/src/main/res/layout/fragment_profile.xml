<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/topBarHeight"
        android:background="@drawable/bg_top_bar_rounded"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing4">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/plus_jakarta_sans"
            android:text="@string/nav_profile"
            android:textColor="@color/colorTextPrimary"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/topBarHeight"
        android:padding="@dimen/spacing4">

            <!-- Personal info card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPersonalInfo"
                style="@style/Widget.Hom8.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing3">

                    <com.hom8.app.presentation.common.WireAvatar
                        android:id="@+id/avatarProfile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:wireAvatarSize="lg"
                        app:wireInitials="U" />

                    <TextView
                        android:id="@+id/tvProfileName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing2"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        tools:text="Ana GarcÃ­a" />

                    <TextView
                        android:id="@+id/tvProfileEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:textColor="@color/colorTextTertiary"
                        android:textSize="12sp"
                        tools:text="ana@email.com" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Stats card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStats"
                style="@style/Widget.Hom8.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing4"
                app:layout_constraintTop_toBottomOf="@id/cardPersonalInfo"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing3">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing2"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:letterSpacing="0.05"
                        android:text="@string/profile_my_stats"
                        android:textColor="@color/colorTextTertiary"
                        android:textSize="10sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Tasks done -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvTasksDone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/plus_jakarta_sans"
                                android:textColor="@color/colorPrimary"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                tools:text="42" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/plus_jakarta_sans"
                                android:text="@string/profile_tasks_done"
                                android:textColor="@color/colorTextTertiary"
                                android:textSize="10sp" />

                        </LinearLayout>

                        <!-- Streak -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvStreak"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/plus_jakarta_sans"
                                android:textColor="@color/colorSecondary"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                tools:text="7d" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/plus_jakarta_sans"
                                android:text="@string/profile_streak"
                                android:textColor="@color/colorTextTertiary"
                                android:textSize="10sp" />

                        </LinearLayout>

                        <!-- Score -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvScore"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/plus_jakarta_sans"
                                android:textColor="@color/colorTertiary"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                tools:text="320" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/plus_jakarta_sans"
                                android:text="@string/profile_score"
                                android:textColor="@color/colorTextTertiary"
                                android:textSize="10sp" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Dark Mode Toggle Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDarkMode"
                style="@style/Widget.Hom8.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing4"
                app:layout_constraintTop_toBottomOf="@id/cardStats"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="@dimen/spacing3">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:text="Modo Oscuro"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchDarkMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:thumbTint="@color/switch_thumb_color"
                        app:trackTint="@color/switch_track_color" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- My Home card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMyHome"
                style="@style/Widget.Hom8.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing4"
                app:layout_constraintTop_toBottomOf="@id/cardDarkMode"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing3">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing2"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:letterSpacing="0.05"
                        android:text="@string/profile_my_home"
                        android:textColor="@color/colorTextTertiary"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/tvHomeName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing2"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="GarcÃ­a Family Home" />

                    <!-- Invite code row -->
                    <LinearLayout
                        android:id="@+id/layoutInviteCode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:minHeight="48dp"
                        android:padding="@dimen/spacing2">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:text="@string/profile_invite_code"
                            android:textColor="@color/colorTextTertiary"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/tvInviteCode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:textColor="@color/colorPrimary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="HF-ABCD12" />

                        <TextView
                            android:id="@+id/tvCopyCode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing2"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:text="@string/profile_copy"
                            android:textColor="@color/colorPrimary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvShareLink"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing2"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:text="Compartir"
                            android:textColor="@color/colorPrimary"
                            android:textSize="11sp" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Action Buttons -->
            <LinearLayout
                android:id="@+id/layoutButtons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="@dimen/spacing3"
                app:layout_constraintTop_toBottomOf="@id/cardMyHome"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <!-- Manage Homes button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnManageHomes"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:text="@string/profile_manage_homes"
                    android:textColor="@color/colorPrimary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:cornerRadius="12dp"
                    app:strokeColor="@color/colorPrimary" />

                <!-- View Members button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnViewMembers"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="@dimen/spacing2"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:text="@string/members_view_button"
                    android:textColor="@color/colorPrimary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:cornerRadius="12dp"
                    app:strokeColor="@color/colorPrimary" />

                <!-- Log Out button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogOut"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="@dimen/spacing2"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:text="@string/action_log_out"
                    android:textColor="@color/colorError"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:cornerRadius="12dp"
                    app:strokeColor="@color/colorError" />

            </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
