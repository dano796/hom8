<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/topBarHeight"
        android:background="@color/colorSurface"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing4">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/jetbrains_mono"
            android:text="@string/nav_profile"
            android:textColor="@color/colorTextPrimary"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/topBarHeight"
        android:overScrollMode="never"
        android:paddingBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing4">

            <!-- Personal info card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.HomeFlow.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing3">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing4">

                    <com.homeflow.app.presentation.common.WireAvatar
                        android:id="@+id/avatarProfile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:wireAvatarSize="lg"
                        app:wireInitials="U" />

                    <TextView
                        android:id="@+id/tvProfileName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing3"
                        android:fontFamily="@font/jetbrains_mono"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        tools:text="Ana GarcÃ­a" />

                    <TextView
                        android:id="@+id/tvProfileEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/jetbrains_mono"
                        android:textColor="@color/colorTextTertiary"
                        android:textSize="13sp"
                        tools:text="ana@email.com" />

                    <TextView
                        android:id="@+id/tvMemberSince"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/jetbrains_mono"
                        android:textColor="@color/colorTextTertiary"
                        android:textSize="11sp"
                        tools:text="Member since April 2025" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Stats card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.HomeFlow.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing3">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing4">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing3"
                        android:fontFamily="@font/jetbrains_mono"
                        android:letterSpacing="0.05"
                        android:text="@string/profile_my_stats"
                        android:textColor="@color/colorTextTertiary"
                        android:textSize="11sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Tasks done -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvTasksDone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/jetbrains_mono"
                                android:textColor="@color/colorPrimary"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                tools:text="42" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/jetbrains_mono"
                                android:text="@string/profile_tasks_done"
                                android:textColor="@color/colorTextTertiary"
                                android:textSize="11sp" />

                        </LinearLayout>

                        <!-- Streak -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvStreak"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/jetbrains_mono"
                                android:textColor="@color/colorSecondary"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                tools:text="7d" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/jetbrains_mono"
                                android:text="@string/profile_streak"
                                android:textColor="@color/colorTextTertiary"
                                android:textSize="11sp" />

                        </LinearLayout>

                        <!-- Score -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvScore"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/jetbrains_mono"
                                android:textColor="@color/colorTertiary"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                tools:text="320" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/jetbrains_mono"
                                android:text="@string/profile_score"
                                android:textColor="@color/colorTextTertiary"
                                android:textSize="11sp" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- My Home card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.HomeFlow.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing3">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing4">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing3"
                        android:fontFamily="@font/jetbrains_mono"
                        android:letterSpacing="0.05"
                        android:text="@string/profile_my_home"
                        android:textColor="@color/colorTextTertiary"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tvHomeName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing2"
                        android:fontFamily="@font/jetbrains_mono"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        tools:text="GarcÃ­a Family Home" />

                    <!-- Invite code row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:background="@color/colorSurfaceVariant"
                        android:padding="@dimen/spacing2">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/jetbrains_mono"
                            android:text="@string/profile_invite_code"
                            android:textColor="@color/colorTextTertiary"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/tvInviteCode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/jetbrains_mono"
                            android:textColor="@color/colorPrimary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="HF-ABCD12" />

                        <TextView
                            android:id="@+id/tvCopyCode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing2"
                            android:fontFamily="@font/jetbrains_mono"
                            android:text="@string/profile_copy"
                            android:textColor="@color/colorPrimary"
                            android:textSize="11sp" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Manage Homes button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnManageHomes"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="@dimen/spacing4"
                android:fontFamily="@font/jetbrains_mono"
                android:text="@string/profile_manage_homes"
                android:textColor="@color/colorPrimary"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                app:strokeColor="@color/colorPrimary" />

            <!-- View Members button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewMembers"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="@dimen/spacing4"
                android:fontFamily="@font/jetbrains_mono"
                android:text="@string/members_view_button"
                android:textColor="@color/colorPrimary"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                app:strokeColor="@color/colorPrimary" />

            <!-- Log Out button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogOut"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="@dimen/spacing4"
                android:fontFamily="@font/jetbrains_mono"
                android:text="@string/action_log_out"
                android:textColor="@color/colorError"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                app:strokeColor="@color/colorError" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing2"
                android:fontFamily="@font/jetbrains_mono"
                android:gravity="center"
                android:text="@string/profile_logout_hint"
                android:textColor="@color/colorTextTertiary"
                android:textSize="11sp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
