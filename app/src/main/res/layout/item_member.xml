<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="@dimen/spacing4"
    android:paddingVertical="@dimen/spacing3">

    <com.hom8.app.presentation.common.WireAvatar
        android:id="@+id/avatarMember"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:wireAvatarSize="md"
        app:wireInitials="AB" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing3"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvMemberName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="Ana García" />

            <TextView
                android:id="@+id/tvMemberYou"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_label_chip"
                android:fontFamily="@font/plus_jakarta_sans"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="@string/members_you"
                android:textColor="@color/colorPrimary"
                android:textSize="10sp"
                android:visibility="gone" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvMemberEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/plus_jakarta_sans"
            android:textColor="@color/colorTextTertiary"
            android:textSize="12sp"
            tools:text="ana@email.com" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvMemberRole"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/plus_jakarta_sans"
        android:textColor="@color/colorTextTertiary"
        android:textSize="11sp"
        tools:text="Admin" />

</LinearLayout>
