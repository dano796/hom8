<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/topBarHeight"
        android:background="@drawable/bg_top_bar_rounded"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing4">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/plus_jakarta_sans"
            android:text="@string/nav_calendar"
            android:textColor="@color/colorTextPrimary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Monthly/Weekly toggle -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipMonthly"
                style="@style/Widget.Hom8.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="@string/calendar_monthly" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipWeekly"
                style="@style/Widget.Hom8.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/calendar_weekly" />

        </com.google.android.material.chip.ChipGroup>

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/topBarHeight"
        android:overScrollMode="never"
        android:paddingBottom="80dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Month navigation header -->
            <LinearLayout
                android:id="@+id/layoutMonthNav"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/colorSurface"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/spacing3">

                <ImageButton
                    android:id="@+id/btnPrevMonth"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Previous month"
                    android:src="@drawable/ic_back"
                    app:tint="@color/colorTextSecondary" />

                <TextView
                    android:id="@+id/tvMonthYear"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:gravity="center"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    tools:text="April 2025" />

                <ImageButton
                    android:id="@+id/btnNextMonth"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Next month"
                    android:src="@drawable/ic_next"
                    app:tint="@color/colorTextSecondary" />

            </LinearLayout>

            <!-- Day-of-week headers -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="@color/colorSurface"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/spacing2">

                <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:fontFamily="@font/plus_jakarta_sans" android:text="Lu" android:textColor="@color/colorTextTertiary" android:textSize="11sp" />
                <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:fontFamily="@font/plus_jakarta_sans" android:text="Ma" android:textColor="@color/colorTextTertiary" android:textSize="11sp" />
                <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:fontFamily="@font/plus_jakarta_sans" android:text="Mi" android:textColor="@color/colorTextTertiary" android:textSize="11sp" />
                <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:fontFamily="@font/plus_jakarta_sans" android:text="Ju" android:textColor="@color/colorTextTertiary" android:textSize="11sp" />
                <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:fontFamily="@font/plus_jakarta_sans" android:text="Vi" android:textColor="@color/colorTextTertiary" android:textSize="11sp" />
                <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:fontFamily="@font/plus_jakarta_sans" android:text="Sa" android:textColor="@color/colorTextTertiary" android:textSize="11sp" />
                <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:fontFamily="@font/plus_jakarta_sans" android:text="Do" android:textColor="@color/colorTextTertiary" android:textSize="11sp" />

            </LinearLayout>

            <!-- Calendar grid (filled programmatically) -->
            <GridLayout
                android:id="@+id/calendarGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/colorSurface"
                android:columnCount="7"
                android:paddingBottom="@dimen/spacing2"
                android:paddingHorizontal="@dimen/spacing2" />

            <!-- Tasks for selected day -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="@dimen/spacing3">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/spacing4"
                    android:paddingBottom="@dimen/spacing2">

                    <TextView
                        android:id="@+id/tvSelectedDay"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        tools:text="Tasks for April 15" />

                    <TextView
                        android:id="@+id/tvDayTaskCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:textColor="@color/colorTextTertiary"
                        android:textSize="11sp"
                        tools:text="3 tasks" />

                </LinearLayout>

                <!-- Tasks list for selected day -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvDayTasks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/spacing4"
                    android:nestedScrollingEnabled="false"
                    tools:itemCount="3"
                    tools:listitem="@layout/item_task_upcoming" />

                <!-- Empty day state -->
                <LinearLayout
                    android:id="@+id/layoutDayEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing5"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:gravity="center"
                        android:text="No hay tareas en este día"
                        android:textColor="@color/colorTextTertiary"
                        android:textSize="13sp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
