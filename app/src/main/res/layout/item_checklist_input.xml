<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:layout_marginBottom="@dimen/spacing2">

    <CheckBox
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginEnd="@dimen/spacing2"
        android:button="@null"
        android:background="@drawable/ic_checkbox"
        android:enabled="false" />

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        app:boxCornerRadiusBottomEnd="8dp"
        app:boxCornerRadiusBottomStart="8dp"
        app:boxCornerRadiusTopEnd="8dp"
        app:boxCornerRadiusTopStart="8dp"
        app:boxStrokeColor="@color/inputBorder">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etChecklistItem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/plus_jakarta_sans"
            android:inputType="textCapSentences"
            android:textColor="@color/colorTextPrimary"
            android:textSize="13sp" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Touch target size: min 48dp x 48dp -->
    <ImageButton
        android:id="@+id/btnRemoveItem"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Remove subtask"
        android:scaleType="centerInside"
        android:src="@drawable/ic_delete"
        app:tint="@color/colorTextTertiary" />

</LinearLayout>
