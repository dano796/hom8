<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.Hom8.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:layout_marginBottom="@dimen/spacing2">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing3">

        <!-- Row 1: Checkbox + Title + Priority + Menu -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Touch target size: min 48dp x 48dp -->
            <CheckBox
                android:id="@+id/cbTaskDone"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="8dp"
                android:button="@null"
                android:background="@drawable/ic_checkbox"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/plus_jakarta_sans"
                android:maxLines="2"
                android:ellipsize="end"
                android:textColor="@color/colorTextPrimary"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="Clean the kitchen thoroughly" />

            <TextView
                android:id="@+id/tvPriority"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing2"
                android:fontFamily="@font/plus_jakarta_sans"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:textSize="10sp"
                android:textStyle="bold"
                tools:background="@drawable/bg_priority_medium"
                tools:text="MED"
                tools:textColor="@color/priorityMediumText" />

            <!-- Touch target size: min 48dp x 48dp -->
            <ImageButton
                android:id="@+id/btnTaskMenu"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Task menu"
                android:scaleType="centerInside"
                android:src="@drawable/ic_more"
                app:tint="@color/colorTextTertiary" />

        </LinearLayout>

        <!-- Row 2: Avatar + Due date + Status chip -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing2"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.hom8.app.presentation.common.WireAvatar
                android:id="@+id/avatarAssignee"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/spacing2"
                app:wireAvatarSize="xs"
                app:wireInitials="A" />

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginEnd="4dp"
                android:src="@drawable/ic_clock"
                app:tint="@color/colorTextTertiary" />

            <TextView
                android:id="@+id/tvDueDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textColor="@color/colorTextTertiary"
                android:textSize="11sp"
                tools:text="Tomorrow, 6:00 PM" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/plus_jakarta_sans"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:textSize="10sp"
                android:textStyle="bold"
                tools:background="@drawable/bg_status_pending"
                tools:text="PENDING"
                tools:textColor="@color/statusPendingText" />

        </LinearLayout>

        <!-- Row 3: Label chips (shown only when there are labels) -->
        <HorizontalScrollView
            android:id="@+id/scrollLabels"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing2"
            android:scrollbars="none"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/layoutLabels"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />

        </HorizontalScrollView>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
