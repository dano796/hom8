<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingVertical="@dimen/spacing2"
    android:paddingHorizontal="@dimen/spacing1">

    <!-- Left colored bar (priority indicator) -->
    <View
        android:id="@+id/viewPriorityBar"
        android:layout_width="3dp"
        android:layout_height="36dp"
        android:layout_marginEnd="@dimen/spacing3"
        android:background="#4361EE"
        tools:background="@color/colorPrimary" />

    <!-- Task info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvUpcomingTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/jetbrains_mono"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="@color/colorTextPrimary"
            android:textSize="13sp"
            android:textStyle="bold"
            tools:text="Buy groceries" />

        <TextView
            android:id="@+id/tvUpcomingDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/jetbrains_mono"
            android:textColor="@color/colorTextTertiary"
            android:textSize="11sp"
            tools:text="Tomorrow · 3:00 PM" />

    </LinearLayout>

    <!-- Assignee avatar -->
    <com.homeflow.app.presentation.common.WireAvatar
        android:id="@+id/avatarAssignee"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing2"
        app:wireAvatarSize="xs"
        app:wireInitials="A" />

</LinearLayout>
