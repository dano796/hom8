<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/topBarHeight"
        android:background="@drawable/bg_top_bar_rounded"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing4">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="@dimen/spacing3"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            android:contentDescription="Back"
            app:tint="@color/colorTextSecondary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/jetbrains_mono"
            android:text="@string/expenses_new_expense"
            android:textColor="@color/colorTextPrimary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:id="@+id/tvToolbarTitle" />

        <TextView
            android:id="@+id/tvCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/jetbrains_mono"
            android:text="@string/action_cancel"
            android:textColor="@color/colorTextTertiary"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- Scrollable form -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/topBarHeight"
        android:overScrollMode="never"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing4">

            <!-- Description -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilDescription"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing3"
                android:hint="@string/expenses_description_label"
                app:boxCornerRadiusBottomEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusTopStart="8dp"
                app:boxStrokeColor="@color/colorOutline"
                app:hintTextColor="@color/colorTextTertiary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/jetbrains_mono"
                    android:inputType="text"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Amount row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing3"
                android:orientation="horizontal">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilAmount"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/spacing2"
                    android:layout_weight="1"
                    android:hint="@string/expenses_amount_label"
                    app:boxCornerRadiusBottomEnd="8dp"
                    app:boxCornerRadiusBottomStart="8dp"
                    app:boxCornerRadiusTopEnd="8dp"
                    app:boxCornerRadiusTopStart="8dp"
                    app:boxStrokeColor="@color/colorOutline"
                    app:hintTextColor="@color/colorTextTertiary"
                    app:prefixText="COP "
                    app:prefixTextColor="@color/colorTextSecondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etAmount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/jetbrains_mono"
                        android:inputType="numberDecimal"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="14sp" />

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <!-- Paid by section (visible in SPLIT mode only) -->
            <LinearLayout
                android:id="@+id/layoutPaidBy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing2"
                    android:fontFamily="@font/jetbrains_mono"
                    android:letterSpacing="0.05"
                    android:text="@string/expenses_paid_by"
                    android:textColor="@color/colorTextTertiary"
                    android:textSize="11sp" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupPaidBy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing4"
                    app:singleSelection="true"
                    app:selectionRequired="true" />

            </LinearLayout>

            <!-- Category section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing2"
                android:fontFamily="@font/jetbrains_mono"
                android:letterSpacing="0.05"
                android:text="@string/expenses_category"
                android:textColor="@color/colorTextTertiary"
                android:textSize="11sp" />

            <!-- Category grid 3x2 -->
            <GridLayout
                android:id="@+id/gridCategory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing4"
                android:columnCount="3"
                android:rowCount="3">

                <!-- Comida -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/catFood"
                    style="@style/Widget.HomeFlow.Card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing2">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/jetbrains_mono" android:text="@string/expense_category_food" android:textColor="@color/colorTextPrimary" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- SUPERMercado -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/catSupermarket"
                    style="@style/Widget.HomeFlow.Card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing2">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/jetbrains_mono" android:text="@string/expense_category_market" android:textColor="@color/colorTextPrimary" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Servicios -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/catServices"
                    style="@style/Widget.HomeFlow.Card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing2">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/jetbrains_mono" android:text="@string/expense_category_utilities" android:textColor="@color/colorTextPrimary" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Transporte -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/catTransport"
                    style="@style/Widget.HomeFlow.Card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing2">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/jetbrains_mono" android:text="@string/expense_category_transport" android:textColor="@color/colorTextPrimary" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ENTERTAINMENT -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/catEntertainment"
                    style="@style/Widget.HomeFlow.Card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing2">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/jetbrains_mono" android:text="@string/expense_category_leisure" android:textColor="@color/colorTextPrimary" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Otros -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/catOther"
                    style="@style/Widget.HomeFlow.Card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing2">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/jetbrains_mono" android:text="@string/expense_category_other" android:textColor="@color/colorTextPrimary" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

            <!-- Date row -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing2"
                android:fontFamily="@font/jetbrains_mono"
                android:letterSpacing="0.05"
                android:text="@string/expenses_date"
                android:textColor="@color/colorTextTertiary"
                android:textSize="11sp" />

            <LinearLayout
                android:id="@+id/rowDate"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="@dimen/spacing4"
                android:background="@drawable/bg_input_outlined"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/spacing3">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="@dimen/spacing2"
                    android:src="@drawable/ic_calendar"
                    app:tint="@color/colorTextTertiary" />

                <TextView
                    android:id="@+id/tvSelectedDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/jetbrains_mono"
                    android:text="@string/expenses_date_today"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="13sp" />

            </LinearLayout>

            <!-- Note -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilNote"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing4"
                android:hint="@string/expenses_note_label"
                app:boxCornerRadiusBottomEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusTopStart="8dp"
                app:boxStrokeColor="@color/colorOutline"
                app:hintTextColor="@color/colorTextTertiary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/jetbrains_mono"
                    android:inputType="textMultiLine"
                    android:minLines="2"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Save button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveExpense"
                style="@style/Widget.HomeFlow.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/expenses_save_expense" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelExpense"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="@dimen/spacing2"
                android:fontFamily="@font/jetbrains_mono"
                android:text="@string/action_cancel"
                android:textColor="@color/colorTextTertiary" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>



