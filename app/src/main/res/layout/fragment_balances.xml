<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/topBarHeight"
        android:background="@color/colorSurface"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing4">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="@dimen/spacing3"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            android:contentDescription="Back"
            app:tint="@color/colorTextSecondary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/jetbrains_mono"
            android:text="@string/expenses_balance"
            android:textColor="@color/colorTextPrimary"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/topBarHeight"
        android:overScrollMode="never"
        android:paddingBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing4">

            <!-- Net Position card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.HomeFlow.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing3">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing4">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/jetbrains_mono"
                        android:letterSpacing="0.08"
                        android:text="@string/expenses_net_position"
                        android:textColor="@color/colorTextTertiary"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tvNetAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing2"
                        android:fontFamily="@font/jetbrains_mono"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        tools:text="+$40.00"
                        tools:textColor="@color/balancePositive" />

                    <TextView
                        android:id="@+id/tvNetLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/jetbrains_mono"
                        android:textColor="@color/colorTextTertiary"
                        android:textSize="12sp"
                        tools:text="Overall you are owed money" />

                    <!-- Stats row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing4"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvTheyOweTotal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/jetbrains_mono"
                                android:textColor="@color/balancePositive"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                tools:text="$85.00" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/jetbrains_mono"
                                android:text="@string/expenses_they_owe_you"
                                android:textColor="@color/colorTextTertiary"
                                android:textSize="10sp" />

                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="32dp"
                            android:background="@color/colorOutlineVariant" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvYouOweTotal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/jetbrains_mono"
                                android:textColor="@color/balanceNegative"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                tools:text="$45.00" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/jetbrains_mono"
                                android:text="@string/expenses_you_owe"
                                android:textColor="@color/colorTextTertiary"
                                android:textSize="10sp" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Pending settlements section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing2"
                android:fontFamily="@font/jetbrains_mono"
                android:letterSpacing="0.08"
                android:text="@string/expenses_pending_settlements"
                android:textColor="@color/colorTextTertiary"
                android:textSize="11sp" />

            <LinearLayout
                android:id="@+id/layoutPendingSettlements"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing4"
                android:orientation="vertical" />

            <!-- All settled empty state -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAllSettled"
                style="@style/Widget.HomeFlow.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing4"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing5">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✅"
                        android:textSize="32sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing2"
                        android:fontFamily="@font/jetbrains_mono"
                        android:gravity="center"
                        android:text="@string/expenses_all_settled"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Settled payments section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing2"
                android:fontFamily="@font/jetbrains_mono"
                android:letterSpacing="0.08"
                android:text="@string/expenses_settled_payments"
                android:textColor="@color/colorTextTertiary"
                android:textSize="11sp" />

            <LinearLayout
                android:id="@+id/layoutSettledPayments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
