<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.HomeFlow.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:layout_marginBottom="@dimen/spacing2">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/spacing3">

        <!-- Touch target size: min 48dp x 48dp -->
        <CheckBox
            android:id="@+id/cbTaskDone"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="@dimen/spacing3"
            android:button="@null"
            android:background="@drawable/ic_checkbox"
            android:clickable="true"
            android:focusable="true" />

        <!-- Task info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTaskTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/jetbrains_mono"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="@color/colorTextPrimary"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="Clean the kitchen" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/ivDueIcon"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginEnd="4dp"
                    android:src="@drawable/ic_clock"
                    app:tint="@color/colorTextTertiary" />

                <TextView
                    android:id="@+id/tvDueTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/jetbrains_mono"
                    android:textColor="@color/colorTextTertiary"
                    android:textSize="11sp"
                    tools:text="By 6:00 PM" />

            </LinearLayout>

        </LinearLayout>

        <!-- Priority badge -->
        <TextView
            android:id="@+id/tvPriority"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing2"
            android:fontFamily="@font/jetbrains_mono"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:textSize="10sp"
            android:textStyle="bold"
            tools:background="@drawable/bg_priority_medium"
            tools:text="MED"
            tools:textColor="@color/priorityMediumText" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
